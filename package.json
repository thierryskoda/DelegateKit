{
  "name": "delegatekit",
  "private": true,
  "description": "Toolkit for building maintainer-operated AI assistants.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thierryskoda/DelegateKit.git"
  },
  "bugs": {
    "url": "https://github.com/thierryskoda/DelegateKit/issues"
  },
  "homepage": "https://github.com/thierryskoda/DelegateKit#readme",
  "packageManager": "npm@11.12.1",
  "type": "module",
  "engines": {
    "node": "24.15.0"
  },
  "workspaces": [
    "apps/backend",
    "apps/connect",
    "packages/backend-jobs",
    "packages/boldsign-contracts",
    "packages/connected-accounts",
    "packages/capability-catalog",
    "packages/capability-lifecycle",
    "packages/connect-api-contracts",
    "packages/control-db",
    "packages/control-plane-contracts",
    "packages/codex-agent",
    "packages/document-contracts",
    "packages/file-analysis-contracts",
    "packages/errors",
    "packages/gmail-contracts",
    "packages/google-calendar-contracts",
    "packages/google-drive-contracts",
    "packages/guidance-authoring",
    "packages/llm-client",
    "packages/llm-judge",
    "packages/microsoft-onedrive-contracts",
    "packages/microsoft-sharepoint-contracts",
    "packages/microsoft-todo-contracts",
    "packages/monday-contracts",
    "packages/nango-provisioning",
    "packages/outlook-calendar-contracts",
    "packages/outlook-mail-contracts",
    "packages/phone-contracts",
    "packages/profile-files-contracts",
    "packages/assistant-capability-surface",
    "packages/repo-layout",
    "packages/runtime-guidance",
    "packages/runtime-diagnostics",
    "packages/tool-contracts",
    "packages/public-web-contracts",
    "packages/profile-context-contracts",
    "packages/workspace-shared",
    "packages/time-contracts",
    "packages/work-contracts",
    "packages/scheduled-tasks-contracts",
    "packages/actions-contracts",
    "packages/proposals-contracts",
    "packages/profile-links-contracts"
  ],
  "overrides": {
    "node-domexception": "npm:@nolyfill/domexception@1.0.28"
  },
  "scripts": {
    "start": "tsx scripts/profiles/start.ts --profile=dev",
    "start:dev": "tsx scripts/profiles/start.ts --profile=dev",
    "start:dev:fast": "tsx scripts/profiles/start.ts --profile=dev --fast",
    "start:dev:watch": "tsx scripts/profiles/start.ts --profile=dev --watch",
    "build:packages": "turbo run build",
    "build": "npm run build:packages",
    "guard": "tsx scripts/repo-tooling/guards/guard.ts",
    "check": "tsx scripts/repo-tooling/verify.ts source-fast",
    "review:source": "npm run verify:source",
    "verify": "tsx scripts/repo-tooling/verify.ts source",
    "verify:source": "tsx scripts/repo-tooling/verify.ts source",
    "verify:source-fast": "tsx scripts/repo-tooling/verify.ts source-fast",
    "verify:runtime": "tsx scripts/repo-tooling/verify.ts runtime",
    "verify:all": "tsx scripts/repo-tooling/verify.ts all",
    "tools:inventory": "tsx scripts/repo-tooling/tool-inventory.ts",
    "profile": "tsx scripts/profiles/profile-cli.ts",
    "tunnel": "tsx scripts/tunnel/tunnel.ts",
    "env:check": "tsx scripts/profiles/env.ts",
    "clients": "tsx scripts/clients/clients.ts",
    "integrations": "tsx scripts/integrations/integrations.ts",
    "backend:serve": "tsx apps/backend/src/server.ts",
    "backend:dev": "tsx watch --clear-screen=false apps/backend/src/server.ts",
    "backend:worker": "tsx apps/backend/src/worker.ts",
    "backend:worker:dev": "tsx watch --clear-screen=false apps/backend/src/worker.ts",
    "db": "tsx scripts/repo-tooling/db.ts",
    "e2e": "tsx scripts/repo-tooling/run-e2e-tests.ts",
    "e2e:lanes": "tsx scripts/repo-tooling/e2e-lanes-cli.ts",
    "e2e:lane-status": "tsx scripts/repo-tooling/e2e-lanes-cli.ts status",
    "e2e:sweep": "tsx scripts/repo-tooling/e2e-sweep/e2e-sweep.ts",
    "e2e:cleanup-fixtures": "tsx scripts/repo-tooling/e2e-fixtures/cleanup-stale-fixtures.ts",
    "test": "npm run test:scripts",
    "test:scripts": "npm run guard -- e2e-harness",
    "typecheck": "turbo run typecheck && tsc -p tsconfig.scripts.json --noEmit",
    "format": "prettier --write .",
    "knip": "knip --no-progress",
    "knip:e2e": "knip --config knip.e2e.json --workspace '@ai-assistants/workspace' --exports",
    "smoke:apps-sdk-mcp": "tsx scripts/smoke/apps-sdk-mcp.ts",
    "smoke:codex-agent": "tsx scripts/smoke/codex-agent.ts",
    "diagnostics": "tsx scripts/diagnostics/diagnostics.ts"
  },
  "devDependencies": {
    "@ai-assistants/actions-contracts": "*",
    "@ai-assistants/backend-jobs": "*",
    "@ai-assistants/boldsign-contracts": "^0.1.0",
    "@ai-assistants/capability-catalog": "*",
    "@ai-assistants/capability-lifecycle": "*",
    "@ai-assistants/codex-agent": "*",
    "@ai-assistants/connect-api-contracts": "^0.1.0",
    "@ai-assistants/connected-accounts": "*",
    "@ai-assistants/control-db": "*",
    "@ai-assistants/control-plane-contracts": "*",
    "@ai-assistants/document-contracts": "^0.1.0",
    "@ai-assistants/errors": "^0.1.0",
    "@ai-assistants/file-analysis-contracts": "*",
    "@ai-assistants/gmail-contracts": "*",
    "@ai-assistants/google-calendar-contracts": "*",
    "@ai-assistants/google-drive-contracts": "^0.1.0",
    "@ai-assistants/guidance-authoring": "*",
    "@ai-assistants/llm-client": "*",
    "@ai-assistants/llm-judge": "^0.1.0",
    "@ai-assistants/microsoft-onedrive-contracts": "*",
    "@ai-assistants/microsoft-sharepoint-contracts": "*",
    "@ai-assistants/microsoft-todo-contracts": "*",
    "@ai-assistants/monday-contracts": "*",
    "@ai-assistants/nango-provisioning": "*",
    "@ai-assistants/outlook-calendar-contracts": "*",
    "@ai-assistants/outlook-mail-contracts": "*",
    "@ai-assistants/phone-contracts": "*",
    "@ai-assistants/assistant-capability-surface": "*",
    "@ai-assistants/profile-context-contracts": "*",
    "@ai-assistants/profile-files-contracts": "*",
    "@ai-assistants/profile-links-contracts": "*",
    "@ai-assistants/proposals-contracts": "*",
    "@ai-assistants/public-web-contracts": "*",
    "@ai-assistants/repo-layout": "*",
    "@ai-assistants/runtime-diagnostics": "*",
    "@ai-assistants/runtime-guidance": "*",
    "@ai-assistants/scheduled-tasks-contracts": "*",
    "@ai-assistants/time-contracts": "*",
    "@ai-assistants/tool-contracts": "*",
    "@ai-assistants/work-contracts": "*",
    "@ai-assistants/workspace-shared": "^0.1.0",
    "@ast-grep/cli": "^0.42.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@napi-rs/canvas": "^0.1.100",
    "@supabase/supabase-js": "^2.105.4",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.15.6",
    "knip": "^6.12.0",
    "pg": "^8.16.3",
    "pizzip": "^3.2.0",
    "prettier": "^3.8.3",
    "ts-to-zod": "^5.1.0",
    "tsx": "^4.19.4",
    "turbo": "^2.9.16",
    "twilio": "^6.0.2",
    "typescript": "^5.8.3",
    "zod": "^4.3.6"
  }
}
