# AI assistants profile env template.
#
# Copy this file to the profile env you are setting up, then fill only the
# values that apply:
#   .env.development -> local dev profile env through npm run start:dev
#   .env.e2e        -> local E2E profile env through e2e profile commands
#
# Keep local dev/E2E lean. Do not copy production secrets into local runtime profiles.

# Required. Local profile startup can generate these when missing.
OAUTH_STATE_SECRET=change-this-long-random-secret
AI_ASSISTANTS_BACKEND_MACHINE_TOKEN=change-this-machine-token

# Optional local defaults. npm run start:dev writes profile-specific defaults if
# these are unset.
# Dev defaults: backend 8787, connect 5173, web bridge 15173.
# E2E defaults: backend 8877, connect 5273, web bridge 15273.
# BACKEND_PORT=8787
# AI_ASSISTANTS_BACKEND_URL=http://localhost:8787
# AI_ASSISTANTS_WEB_BRIDGE_PORT=15173

# --- Supabase control plane
# Required. npm run profile -- supabase start --profile=<profile> writes these
# into the active runtime profile env when using repo-managed local Supabase.
# E2E writes isolated values for its local Supabase stack.
# SUPABASE_LOCAL_WORKDIR=/Users/you/.ai-assistants-e2e
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- Connect portal
# Required only for browser builds that use a public local tunnel. Normal
# npm run start:dev parity mode builds Connect against the local backend.
CONNECT_PUBLIC_URL=https://assistant.example.com
BACKEND_PUBLIC_URL=https://assistant.example.com/api
SUPABASE_PUBLIC_URL=https://assistant.example.com/supabase
OAUTH_PUBLIC_URL=https://assistant.example.com
VITE_CONNECT_HMR_HOST=assistant.example.com
# Retired Connect runtime config keys; kept documented so env schema drift is visible.
# VITE_BACKEND_URL=https://assistant.example.com/api
# VITE_SUPABASE_URL=https://assistant.example.com/supabase
# VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# --- Backend and diagnostics
# Required. Repo LLM helpers and judges use this for OpenAI-backed calls.
OPENAI_API_KEY=your_openai_api_key

# Required. Backend assistant runtime uses this for DeepSeek assistant LLM calls.
DEEPSEEK_API_KEY=your_deepseek_api_key

# Required. Backend public web search uses Perplexity.
PERPLEXITY_API_KEY=pplx-your_perplexity_api_key

# Required. Backend public web browser automation uses Browserbase.
BROWSERBASE_API_KEY=bb_live_your_browserbase_api_key

# --- Twilio voice calls
# Required. Backend phone call/SMS workflows use Twilio.
TWILIO_ACCOUNT_SID=AC00000000000000000000000000000000
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Set after purchasing/provisioning a Twilio voice-capable number.
TWILIO_FROM_NUMBER=+10000000000

# --- Live channels
# Optional. Enable channels in control-plane profile channel rows before expecting
# a token to be used.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_MINI_APP_BOT_USERNAME=your_telegram_bot_username
# Required when Telegram webhook ingress points at the backend API.
# TELEGRAM_WEBHOOK_SECRET=change-this-long-random-secret

# --- Nango
# Required for backend API and worker startup. Tokens stay in Nango.
NANGO_SECRET_KEY=00000000-0000-0000-0000-000000000000
NANGO_WEBHOOK_SIGNING_SECRET=00000000-0000-0000-0000-000000000000

# Optional Nango API host override; omit for the default hosted API.
# NANGO_HOST=https://api.nango.dev

# Optional rare override. Prefer source/control-plane provider config keys.
# NANGO_PROVIDER_CONFIG_KEY=

# --- Google providers
# Gmail, Google Drive, Google Calendar, and document workflows can share one
# Google OAuth app when the app has the enabled APIs and scopes.
GOOGLE_OAUTH_CLIENT_ID=000000000000-aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=change-me

# Required only for Gmail watch renewal.
GMAIL_PUBSUB_TOPIC_NAME=projects/your-google-project/topics/your-gmail-topic

# Add provider callbacks to the Google OAuth app:
#   ${OAUTH_PUBLIC_URL}/oauth/gmail/callback
#   ${OAUTH_PUBLIC_URL}/oauth/google-drive/callback
# Google provider webhooks use:
#   ${BACKEND_PUBLIC_URL}/webhooks/google-drive
#   ${BACKEND_PUBLIC_URL}/webhooks/google-calendar

# --- Microsoft providers
MICROSOFT_OAUTH_TENANT_ID=common
MICROSOFT_OAUTH_CLIENT_ID=00000000-0000-0000-0000-000000000000
MICROSOFT_OAUTH_CLIENT_SECRET=change-me

# Add provider callbacks to the Azure App Registration:
#   ${OAUTH_PUBLIC_URL}/oauth/microsoft-onedrive/callback
#   ${OAUTH_PUBLIC_URL}/oauth/microsoft-sharepoint/callback
#   ${OAUTH_PUBLIC_URL}/oauth/outlook/callback
# Microsoft Graph webhooks use:
#   ${BACKEND_PUBLIC_URL}/webhooks/outlook-mail
#   ${BACKEND_PUBLIC_URL}/webhooks/outlook-calendar
#   ${BACKEND_PUBLIC_URL}/webhooks/microsoft-onedrive
#   ${BACKEND_PUBLIC_URL}/webhooks/microsoft-sharepoint

# --- Monday
MONDAY_OAUTH_CLIENT_ID=your_monday_oauth_app_client_id
MONDAY_OAUTH_CLIENT_SECRET=your_monday_oauth_app_client_secret
MONDAY_SIGNING_SECRET=your_monday_app_signing_secret
MONDAY_GRAPHQL_API_VERSION=2026-07

# Add this redirect URI to the monday app OAuth settings:
#   ${OAUTH_PUBLIC_URL}/oauth/monday/callback
# Monday board webhooks use:
#   ${BACKEND_PUBLIC_URL}/webhooks/monday

# --- BoldSign (Canada data center only)
BOLDSIGN_API_KEY=your_boldsign_api_key
BOLDSIGN_DATA_CENTER=ca
# Optional explicit base (must match CA):
# BOLDSIGN_API_BASE_URL=https://api-ca.boldsign.com/v1
BOLDSIGN_WEBHOOK_SIGNING_SECRET=your_boldsign_webhook_signing_secret

# Optional during webhook secret rotation only.
# BOLDSIGN_WEBHOOK_SIGNING_SECRET_OLD=

# BoldSign document webhooks use:
#   ${BACKEND_PUBLIC_URL}/webhooks/boldsign

# --- Video production
ELEVENLABS_API_KEY=your_elevenlabs_api_key
HEDRA_API_KEY=your_hedra_api_key
RUNWAY_API_KEY=your_runway_api_key

# Optional Hedra public web-app API override; omit for the plugin default.
# HEDRA_WEB_PUBLIC_BASE=https://api.hedra.com/web-app/public

# Dev-only. Set to 1 for tiny placeholder MP4s with no vendor spend.
# VIDEO_PRODUCTION_MOCK_PROVIDERS=0

# --- Testing overrides
# Outbound E2E email recipient when a scenario sends mail (testing profile uses real Nango Gmail).
# AI_ASSISTANTS_E2E_GMAIL_TO=real.testing.recipient@yourdomain.com
# Private controlled sender used to seed inbound Gmail/Outlook messages with attachments.
# AI_ASSISTANTS_E2E_CLIENT_EMAIL=controlled.fixture.sender@yourdomain.com
